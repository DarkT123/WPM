# Edge backend configuration
PORT=3002

# MiniMax (or any OpenAI-compatible chat completion service) - optional
# MINIMAX_API_BASE_URL=https://api.minimax.chat
# MINIMAX_API_KEY=
# MINIMAX_MODEL=abab6.5-chat
# MINIMAX_TIMEOUT_MS=200

# Decoder tuning
BEAM_WIDTH=20
MAX_ALTERNATIVES=10
# Sentences with confidence below this trigger the optional AI rerank.
AI_CONFIDENCE_THRESHOLD=0.6
# Sentences with at least this many tokens are considered "long" and trigger AI too.
AI_LONG_SENTENCE=8
